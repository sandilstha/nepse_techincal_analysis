# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# ── Database credentials (MySQL) ───────────────────────────────────────────
DB_NAME=nepse_database
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ── Django ─────────────────────────────────────────────────────────────────
# Leaving DJANGO_DEBUG unset defaults DEBUG to True (local dev).
#
# PRODUCTION: set DJANGO_DEBUG=0. Django then REQUIRES *both* DJANGO_SECRET_KEY
# and a non-empty DJANGO_ALLOWED_HOSTS — miss either and startup aborts with
# "You must set settings.ALLOWED_HOSTS if DEBUG is False." List every IP/domain
# the server is reached on (comma-separated).
# Generate a key:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.60,your-domain.example
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example
# DJANGO_SECURE_SSL_REDIRECT=1        # set 0 if TLS is terminated upstream
# DJANGO_HSTS_SECONDS=31536000

# Persistent DB connections: seconds to keep a MySQL connection open for reuse
# across requests (0 = open/close per request). Default 60.
# DB_CONN_MAX_AGE=60

# ── Caching ──────────────────────────────────────────────────────────────────
# Leave unset for the default in-process cache (fine for a single-process server).
# Set this only when running MULTIPLE worker processes, so the cache + the
# dashboard's cold-build stampede lock are shared across workers (needs: pip install redis).
# REDIS_URL=redis://127.0.0.1:6379/0

# ── Market Insights behaviour ──────────────────────────────────────────────
# NEPSE settles at 3 PM Nepal time. After the close the dashboard switches from
# the intraday live feeds to the settled end-of-day data in SQL (and triggers a
# one-shot background sync). Defaults shown; override only if needed.
# NEPSE_MARKET_CLOSE_HOUR=15
# NEPSE_MARKET_CLOSE_MINUTE=0
# NEPSE_POST_CLOSE_EOD=1              # set 0 to disable the post-close SQL switch

# ── Upstream NEPSE data feeds (optional overrides) ─────────────────────────
# NEPSE_API_BASE_URL=http://192.168.1.35:8000
# NEPSE_API_TOKEN=
# NEPSE_SUBINDICES_URL=http://192.168.1.100:8001/NepseSubIndices
# NEPSE_MARKET_SUMMARY_URL=http://192.168.1.100:8001/MarketSummaryHistory
# NEPSE_TOP_MOVERS_BASE=http://192.168.1.100:8001
# NEPSE_LIVE_PRICE_URL=http://192.168.1.100:3000/api/live-price/
# NEPSE_CONTRIBUTORS_URL=http://192.168.1.35:8000/contributors/
